    "result_df[\"predicted_youtube_highlight_score_temporal_v2_smoothed\"] = all_ensemble_predictions_smoothed\n",
    "result_df[\"temporal_v2_residual_smoothed\"] = (\n",
    "    result_df[TARGET] - result_df[\"predicted_youtube_highlight_score_temporal_v2_smoothed\"]\n",
